@model MaydonozDoner.Controllers.RegisterViewModel

@{
    ViewData["Title"] = "Kayıt Ol";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    body {
        background-color: #121620;
        color: #f1f3f5;
        font-family: 'Outfit', sans-serif;
    }

    .register-container {
        max-width: 480px;
        margin: 50px auto;
    }

    .card-register {
        background: #1a1f2c;
        border: 1px solid #2d3548;
        border-radius: 16px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }

    .card-header-green {
        background: linear-gradient(135deg, #2b9348 0%, #155d27 100%);
        color: #ffffff;
        font-weight: 800;
        font-size: 1.3rem;
        text-align: center;
        padding: 20px;
        letter-spacing: 0.5px;
        border-bottom: 1px solid #2d3548;
    }

    .form-control {
        background-color: #232a3b;
        border: 1px solid #3d4863;
        color: #ffffff;
        border-radius: 10px;
        padding: 12px 15px;
        transition: all 0.2s ease;
    }

    .form-control:focus {
        background-color: #232a3b;
        border-color: #2b9348;
        box-shadow: 0 0 0 3px rgba(43, 147, 72, 0.25);
        color: #ffffff;
    }

    .btn-register {
        background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
        border: none;
        color: #121620;
        font-weight: 700;
        border-radius: 10px;
        padding: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 193, 7, 0.3);
    }

    .btn-register:hover {
        background: linear-gradient(135deg, #ffd54f 0%, #ffa726 100%);
        transform: scale(1.02);
        box-shadow: 0 6px 20px rgba(255, 193, 7, 0.5);
        color: #121620;
    }

    .form-label {
        color: #adb5bd;
        font-weight: 500;
    }

    .text-link {
        color: #ffc107;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s ease;
    }

    .text-link:hover {
        color: #2b9348;
    }

    .validation-summary-errors {
        background-color: rgba(217, 4, 41, 0.1);
        border: 1px solid #d90429;
        color: #ef233c;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 0.9rem;
    }

    .validation-summary-errors ul {
        margin-bottom: 0;
        padding-left: 20px;
    }
</style>

<div class="register-container">
    <div class="card card-register">
        <div class="card-header-green">
            🌿 MAYDONOZ DÖNER YENİ ÜYE KAYDI
        </div>
        <div class="card-body p-4">
            
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Kullanıcı Adı</label>
                    <input asp-for="Username" class="form-control" placeholder="Benzersiz bir kullanıcı adı yazın" required autofocus />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-posta Adresi</label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="E-posta adresinizi girin" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Telefon Numarası</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Örn: 0555 123 45 67" required oninput="this.value = this.value.replace(/[^0-9\s\-\(\)\+]/g, '')" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Şifre</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="En az 4 karakter" required />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Şifre Tekrar</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Şifrenizi doğrulayın" required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-register w-100 mb-3">Hesabımı Oluştur ve Giriş Yap</button>

                <div class="text-center text-muted small">
                    Zaten bir hesabınız var mı? <a asp-action="Login" class="text-link">Giriş Yapın</a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
