<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MaydonozDoner</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MaydonozDoner.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body {
            background-color: #121620;
            color: #f1f3f5;
            font-family: 'Outfit', sans-serif;
        }

        .navbar-custom {
            background-color: #1a1f2c !important; 
            border-bottom: 2px solid #ffc107; 
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            padding: 15px 0;
        }

        .navbar-brand-custom {
            font-weight: 800;
            color: #ffc107 !important; 
            font-size: 1.5rem;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

        .navbar-brand-custom:hover {
            color: #2b9348 !important; 
            transform: scale(1.02);
        }

        .nav-link-custom {
            color: #ced4da !important;
            font-weight: 500;
            transition: all 0.2s ease;
            margin: 0 4px;
            padding: 8px 12px !important;
            border-radius: 8px;
        }

        .nav-link-custom:hover {
            color: #ffc107 !important; 
            background-color: #232a3b;
        }

        footer {
            background-color: #1a1f2c;
            border-top: 1px solid #2d3548 !important;
            padding: 20px 0;
            color: #868e96 !important;
            margin-top: 50px;
        }

        footer a {
            color: #ffc107;
            text-decoration: none;
            transition: color 0.2s ease;
        }

        footer a:hover {
            color: #2b9348;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark navbar-custom mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand navbar-brand-custom" asp-area="" asp-controller="Home" asp-action="Index">
                    🌿 MAYDONOZ DÖNER
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom animate-pulse" asp-area="" asp-controller="Product" asp-action="Index">Döner Menümüz</a>
                        </li>
                        
                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-area="" asp-controller="Employee" asp-action="Index">Çalışan Yönetimi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom text-warning" asp-area="" asp-controller="Admin" asp-action="Index">👑 Yönetici Paneli</a>
                            </li>
                        }
                        
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Privacy">Hakkımızda & Kurallar</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav me-2">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom position-relative" id="openCartBtn" href="#" style="background-color: #232a3b; border: 1px solid #ffc107; color: #ffc107 !important; border-radius: 8px;">
                                <i class="bi bi-cart4 me-1"></i> Sepetim
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cartBadge" style="display: none; font-size: 0.75rem;">0</span>
                            </a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container text-center">
            &copy; 2026 - Maydonoz Döner Yönetim Paneli - <a asp-area="" asp-controller="Home" asp-action="Privacy">Gizlilik Politikası</a>
        </div>
    </footer>

    <div class="modal fade" id="cartModal" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content text-white" style="background-color: #1a1f2c; border: 2px solid #ffc107; border-radius: 16px;">
                <div class="modal-header border-bottom border-secondary">
                    <h5 class="modal-title text-warning fw-bold" id="cartModalLabel">
                        <i class="bi bi-cart4 me-2"></i> Alışveriş Sepetiniz
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <div class="modal-body" id="cartModalBody" style="max-height: 70vh; overflow-y: auto;">
                </div>
                <div class="modal-footer border-top border-secondary d-flex justify-content-between" id="cartModalFooter">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Alışverişe Devam Et</button>
                    <button type="button" class="btn btn-warning text-dark fw-bold rounded-pill px-4" id="btnOrderComplete">
                        Öde ve Sipariş Ver <i class="bi bi-credit-card-2-front-fill ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
